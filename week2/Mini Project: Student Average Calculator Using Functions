#include <stdio.h>

float calculateAverage(int marks[], int n) {
    int i, sum = 0;

    for(i = 0; i < n; i++)
        sum += marks[i];

    return (float)sum / n;
}

int main() {
    int n, i;
    int marks[100];
    float average;

    printf("Enter number of subjects: ");
    scanf("%d", &n);

    printf("Enter marks:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &marks[i]);

    average = calculateAverage(marks, n);

    printf("Average Marks = %.2f\n", average);

    return 0;
}
